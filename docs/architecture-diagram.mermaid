graph TD
    subgraph UI Layer
        UI["Main Textual UI"]
        WIZ["Specification Wizard"]
    end

    subgraph Agent Layer
        SC["Session Controller"]
        AL["Agent Loop"]
        PLAN["Planning Engine"]
        VER["Verification System"]
    end

    subgraph Context Layer
        CE["Context Engine"]
        PA["Prompt Assembler"]
        CB["Context Budget Manager"]
    end

    subgraph Knowledge Layer
        RG["Repository Graph"]
        MP["Memory Pyramid"]
        
        subgraph Memory Levels
            L3["L3: Engineering Profile"]
            L2["L2: Scenario Memory"]
            L1["L1: Engineering Facts"]
            L0["L0: Session Events"]
        end
    end

    subgraph Execution Layer
        AG["Approval Gateway"]
        TR["Tool Runtime"]
        Tools["read, write, edit, bash"]
    end

    subgraph Persistence Layer
        AS["Artifact Store"]
        LOG["Audit Logging"]
    end

    subgraph External
        Prov["LLM Providers"]
    end

    %% Relationships
    UI -->|User Input| SC
    WIZ -->|Outputs Specs| SC
    
    SC -->|Commands| AL
    AL <-->|Create & Evaluate| PLAN
    AL <-->|Trigger| VER
    
    AL -->|Retrieve & Refresh| CE
    CE -->|Collect Context| PA
    PA -->|Enforce Budget| CB
    
    CB -->|Query Structural Data| RG
    CB -->|Query Facts & Profile| MP
    
    MP -.-> L3
    MP -.-> L2
    MP -.-> L1
    MP -.-> L0

    MP -->|Offload Contexts| AS
    AS -->|Record Audits| LOG
    
    AL -->|Propose Actions| AG
    AG -->|Authorize| TR
    TR -->|Stateless Primitives| Tools
    
    PA -->|Assemble & Send Prompt| Prov
    Prov -->|Model Response| AL

    %% Node Styles
    style UI fill:#E1BEE7,stroke:#8E24AA,stroke-width:2px,color:#000
    style WIZ fill:#E1BEE7,stroke:#8E24AA,stroke-width:2px,color:#000
    
    style SC fill:#FFF9C4,stroke:#FBC02D,stroke-width:2px,color:#000
    style AL fill:#FFF9C4,stroke:#FBC02D,stroke-width:2px,color:#000
    style PLAN fill:#FFF9C4,stroke:#FBC02D,stroke-width:2px,color:#000
    style VER fill:#FFF9C4,stroke:#FBC02D,stroke-width:2px,color:#000

    style CE fill:#C8E6C9,stroke:#388E3C,stroke-width:2px,color:#000
    style PA fill:#C8E6C9,stroke:#388E3C,stroke-width:2px,color:#000
    style CB fill:#C8E6C9,stroke:#388E3C,stroke-width:2px,color:#000

    style RG fill:#BBDEFB,stroke:#1976D2,stroke-width:2px,color:#000
    style MP fill:#BBDEFB,stroke:#1976D2,stroke-width:2px,color:#000
    
    style L3 fill:#FFFFFF,stroke:#1976D2,stroke-width:1px,color:#000
    style L2 fill:#FFFFFF,stroke:#1976D2,stroke-width:1px,color:#000
    style L1 fill:#FFFFFF,stroke:#1976D2,stroke-width:1px,color:#000
    style L0 fill:#FFFFFF,stroke:#1976D2,stroke-width:1px,color:#000

    style AG fill:#FFCDD2,stroke:#D32F2F,stroke-width:2px,color:#000
    style TR fill:#FFCDD2,stroke:#D32F2F,stroke-width:2px,color:#000
    style Tools fill:#FFCDD2,stroke:#D32F2F,stroke-width:2px,color:#000

    style AS fill:#CFD8DC,stroke:#455A64,stroke-width:2px,color:#000
    style LOG fill:#CFD8DC,stroke:#455A64,stroke-width:2px,color:#000

    style Prov fill:#F5F5F5,stroke:#757575,stroke-width:2px,stroke-dasharray: 5 5,color:#000
